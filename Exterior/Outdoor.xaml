<UserControl x:Class="GMEPTitle24.Outdoor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GMEPTitle24.Exterior"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:IsFiveOrHigherConverter x:Key="IsFiveOrHigherConverter" />
    </UserControl.Resources>
    <Grid>
        <TabControl>
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Height" Value="25" />
                </Style>
            </TabControl.Resources>
            <TabItem Header="Scope" DataContext="{Binding ExteriorScopeData}">
                <Grid x:Name="MainGrid">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="Row1" Height="*"/>
                            <RowDefinition>
                                <RowDefinition.Style>
                                    <Style TargetType="RowDefinition">
                                        <Setter Property="Height" Value="5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SystemTypeId}" Value="2">
                                                <Setter Property="Height" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </RowDefinition.Style>
                            </RowDefinition>
                            <RowDefinition x:Name="Row3">
                                <RowDefinition.Style>
                                    <Style TargetType="RowDefinition">
                                        <Setter Property="Height" Value="*"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SystemTypeId}" Value="2">
                                                <Setter Property="Height" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </RowDefinition.Style>
                            </RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="4*"/>
                            </Grid.ColumnDefinitions>
                            <GroupBox Grid.Column="0" Header="Main Options">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Vertical">
                                        <Label Content="Project Scope" FontWeight="Bold"/>
                                        <ComboBox SelectedValue="{Binding ProjectScopeId}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                            <ComboBox.Items>
                                                <ComboBoxItem Content="Addition" Tag="1"/>
                                                <ComboBoxItem Content="Alteration" Tag="2"/>
                                                <ComboBoxItem Content="Addition and Alteration" Tag="3"/>
                                                <ComboBoxItem Content="New Construction" Tag="4"/>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <Label Content="Outdoor Lighting Zone" FontWeight="Bold"/>
                                        <ComboBox SelectedValue="{Binding OutdoorLightingZoneId}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                            <ComboBox.Items>
                                                <ComboBoxItem Content="LZ-0: Very Low - Undeveloped Parkland" Tag="1"/>
                                                <ComboBoxItem Content="LZ-1: Low - Rural Areas" Tag="2"/>
                                                <ComboBoxItem Content="LZ-2: Moderate - Urban Clusters" Tag="3"/>
                                                <ComboBoxItem Content="LZ-3: Moderately High - Urban Areas" Tag="4"/>
                                                <ComboBoxItem Content="LZ-4: High - Must be reviewed by CA Energy Commission for Approval" Tag="5"/>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Orientation="Vertical">
                                                <Label Content="Square Footage" FontWeight="Bold"/>
                                                <TextBox Margin="10 0 0 0"  Text="{Binding SquareFootage}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Vertical" Margin="10 0 0 0">
                                                <Label Content="Total Illuminated Hardscape Area" FontWeight="Bold"/>
                                                <TextBox Margin="10 0 0 0" Text="{Binding IlluminatedHardscapeArea}" Width="100" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <Label Content="Type of Lighting System" FontWeight="Bold"/>
                                        <ComboBox SelectedValue="{Binding SystemTypeId}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                            <ComboBox.Items>
                                                <ComboBoxItem Content="Altered Lighting System" Tag="1"/>
                                                <ComboBoxItem Content="New Lighting System" Tag="2"/>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>
                            <GroupBox Grid.Column="2" Header="Occupancy Types">
                                <ListBox ItemsSource="{Binding OccupancyTypes}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Height="20">
                                                    <CheckBox.LayoutTransform>
                                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                                                    </CheckBox.LayoutTransform>
                                                </CheckBox>
                                                <TextBlock Text="|" Margin="15 5 5 15" VerticalAlignment="Center" FontSize="25" Foreground="SlateGray"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                        </Grid>
                        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="LightGray"/>
                        <GroupBox Grid.Row="2" Header="Altered Lighting Options">
                            <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
                                <CheckBox Content="Is your alteration increasing the connected lighting load (Watts)?" IsChecked="{Binding AlterationIncreasedLoad}" FontWeight="Bold"/>
                                <StackPanel Orientation="Vertical">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AlterationIncreasedLoad}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                        <Label Content="Sum Total of Luminaires Being Added or Altered" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox Text="{Binding LuminairesAltered}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                        <Label Content="What is the % of Existing Luminaires Being Altered" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <ComboBox SelectedValue="{Binding AlteredLuminairesPercentageId}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="Greater than or equal to 10% and less then 50%" Tag="1"/>
                                            <ComboBoxItem Content="Greater then or equal to 50%" Tag="2"/>
                                            <ComboBoxItem Content="Less than 10%" Tag="3"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlteredLuminairesPercentageId}" Value="2">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Label Content="What calculation method will you use to determine wattage allowance for compliance" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <ComboBox SelectedValue="{Binding WattageCalculationMethodId}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="Calculated Allowance per §140.7 " Tag="1"/>
                                            <ComboBoxItem Content="40% Reduced Wattage Exception per §141.0(b)2L" Tag="2"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <CheckBox Content="Does the project have outdoor lighting that is controlled from within a dwelling unit?" Margin="0 20 0 0" IsChecked="{Binding DwellingUnitControl}" FontWeight="Bold">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LuminairesAltered, Converter={StaticResource IsFiveOrHigherConverter}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                      
                    </Grid>
                    <Grid x:Name="ProjectCover" Background="White">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.MainView.ProjectLoaded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Label Content="Load Project to Continue" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" FontWeight="Bold" Visibility="Visible"/>
                    </Grid>
                        
                </Grid>

            </TabItem>
            <TabItem Header="Fixtures"/>
            <TabItem Header="Control Areas"/>
        </TabControl>
    </Grid>
</UserControl>
