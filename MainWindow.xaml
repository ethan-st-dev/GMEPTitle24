<Window x:Class="GMEPTitle24.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GMEPTitle24"
        mc:Ignorable="d"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="GMEP Title 24 - NRCC/2022" Height="450" Width="800"
        Icon="/gmep.ico">
    <Window.Resources>
        <local:BindingProxy x:Key="ScopeProxy" Data="{Binding ScopeData}"/>
        <local:BindingProxy x:Key="FilteredBuildingsProxy" Data="{Binding FilteredBuildings}"/>
    </Window.Resources>
    <Grid Background="SlateGray">
        <Border BorderBrush="DarkSlateGray" BorderThickness="2" Margin="10" Background="LightGray">
            <Grid>
                <TabControl  TabStripPlacement="Left">
                    <TabItem x:Name="Indoor">
                        <TabItem.Header>
                            <TextBlock Text="LTI Indoor Lighting" FontSize="20" FontWeight="Bold" Margin="0 5 0 5">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="270" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem x:Name="Outdoor">
                        <TabItem.Header>
                            <TextBlock Text="LTO Outdoor Lighting" FontSize="20" FontWeight="Bold" Margin="0 5 0 5">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="270" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </TabItem.Header>
                        <TabControl>
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Height" Value="25" />
                                </Style>
                            </TabControl.Resources>
                            <TabItem Header="Scope"/>
                            <TabItem Header="Fixtures"/>
                            <TabItem Header="Control Areas"/>
                        </TabControl>
                    </TabItem>
                </TabControl>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="25" Margin="0 0 0 5" VerticalAlignment="Top">
                    <Image x:Name="Loading" Visibility="Collapsed" VerticalAlignment="Center" gif:ImageBehavior.AnimatedSource="Loading.gif" Width="18" Margin="0 0 5 0"/>
                    <TextBlock VerticalAlignment="Center" x:Name="StatusText" Text="" FontSize="14" Margin="0 0 10 0" FontStyle="Italic"/>
                    <Rectangle Width="1"  Fill="Black" VerticalAlignment="Stretch" Margin="0 5 10 0"/>
                    <TextBox Width="100" Margin="0 5 0 0" Text="{Binding ProjectNo}"/>
                    <Button Width="25" VerticalAlignment="Top" Height="20" HorizontalAlignment="Right" Margin="0 5 10 0" Click="Download_Click">
                        <Image Source="Download.png" Width="20" Height="20" VerticalAlignment="Center" Margin="0 0 5 0"/>
                    </Button>
                    <ComboBox x:Name="VersionComboBox" SelectionChanged="Version_SelectionChanged" Width="60" Margin="0 5 0 0" ItemsSource="{Binding ProjectIds}" DisplayMemberPath="Key" SelectedValuePath="Key" SelectedValue="{Binding SelectedVersion}"/>
                    <Button Width="25" VerticalAlignment="Top" Height="20" HorizontalAlignment="Right" Margin="10 5 0 0" Click="Save_Click">
                        <Image Source="Save.png" Width="15" HorizontalAlignment="Center" Height="15" VerticalAlignment="Center" />
                    </Button>
                    <Button Content="Generate" FontWeight="DemiBold" Width="80" VerticalAlignment="Top"  Height="20" HorizontalAlignment="Right" Margin="0 5 10 0" Click="Export_Click" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
