<Window x:Class="GMEPTitle24.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GMEPTitle24"
        mc:Ignorable="d"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Title 24" Height="450" Width="800">
    <Grid Background="SlateGray">
        <Border BorderBrush="DarkSlateGray" BorderThickness="2" Margin="10" Background="LightGray">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="25" Margin="0 0 0 5" VerticalAlignment="Top">
                    <Image VerticalAlignment="Center" gif:ImageBehavior.AnimatedSource="Loading.gif" Width="18" Margin="0 0 5 0"/>
                    <TextBlock VerticalAlignment="Center" x:Name="StatusText" Text="" FontSize="14" Margin="0 0 10 0" FontStyle="Italic"/>
                    <Button Content="Export" Width="100" VerticalAlignment="Top"  Height="20" HorizontalAlignment="Right" Margin="0 5 10 0" />
                </StackPanel>
                <TabControl Margin="0 1 0 0" SelectionChanged="TabControl_SelectionChanged">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Height" Value="25" />
                            <!-- Adjusts the height of the tab headers -->
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="Fixtures">
                    </TabItem>
                    <TabItem Header="Controls"></TabItem>
                </TabControl>
            </Grid>
        </Border>

    </Grid>
</Window>
